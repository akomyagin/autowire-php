{
    "name": "akomyagin/autowire-php",
    "description": "Framework-agnostic PHP DI container with reflection-based constructor autowiring, lifecycle control and interface-aware circular dependency detection.",
    "type": "library",
    "license": "MIT",
    "keywords": ["dependency-injection", "di-container", "autowiring", "reflection", "psr-11"],
    "authors": [
        {
            "name": "Alexander Komyagin",
            "email": "alkom68@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AutowirePHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AutowirePHP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
